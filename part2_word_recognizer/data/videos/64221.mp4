5232,"additiveBackground":566854725,"textPrimary":4281736970,"textSecondary":4285420346,"invertedBackground":4287582745,"overlayBackground":3426098954},"darkThemeColorPalette":{"baseBackground":4280028930,"raisedBackground":4281736970,"additiveBackground":734626885,"textPrimary":4294634976,"textSecondary":4292723628,"invertedBackground":4293111676,"overlayBackground":3426098954},"position":"FACTOID_POSITION_LAST","enableColorSampledText":true}}],"channelNavigationEndpoint":{"clickTrackingParams":"CBIQ040EGAUiEwiXs-i2t-uTAxWVwZUCHeqLFuLKAQSmRGCV","commandMetadata":{"webCommandMetadata":{"url":"/@aslu","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCZy9xs6Tn9vWqN_5l0EEIZA","canonicalBaseUrl":"/@aslu"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/ytc/AIdro_k5Atr3lwlbXz7g9VDRZc1wpr5wE8Mj09QpZrSzo-CL8A=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"YEAR: The ASL sign for \"year\" has two common versions:\n1. A longer version in which the dominant hand travels all the way around the non-dominant hand. See:    • YEAR  \n\n2. A more abbreviated \"advanced\" version of \"year\" in which the dominant hand makes a small forward rotation movement above the non-dominant hand. American Sign Language - ASL  \nLearn sign language at https://www.Lifeprint.com\nDonations appreciated (to help pay for hosting and related expenses). Please help:   \nhttps://www.paypal.com/cgi-bin/webscr...\nThanks!\nOr, if you prefer \"Cash App\" you can use: https://cash.me/$Lifeprint\nWant to order a USB drive with four semesters worth of ASL instruction? (ASL 1, ASL 2, ASL 3, and ASL 4)  for $79.95?  \nSee \"SuperUSB\" in the ASLUniversity bookstore at: https://lifeprint.com/bookstore/books...\n\nFor free ASL Lessons see:    / billvicars  \nTo learn basic fingerspelling see    • ABC's in ASL: Learn how to Fingerspell!  \n\nAbout your instructor:\nhttp://www.lifeprint.com/asl101/pages...\nWarm regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":157,"length":11,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwiXs-i2t-uTAxWVwZUCHeqLFuLKAQSmRGCV","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=zTIJAgTai40","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"zTIJAgTai40","startTimeSeconds":0,"watchEndpointSupportedOnesieConfig":{"html5PlaybackOnesieConfig":{"commonConfig":{"url":"https://rr1---sn-bvvbaxivnuxqjvhj5nu-n4vs.googlevideo.com/initplayback?source=youtube\u0026oeis=1\u0026c=WEB\u0026oad=3200\u0026ovd=3200\u0026oaad=11000\u0026oavd=11000\u0026ocs=700\u0026oewis=1\u0026oputc=1\u0026ofpcc=1\u0026msp=1\u0026odepv=1\u0026id=cd32090204da8b8d\u0026ip=2601%3A642%3A4c01%3A9e6c%3Ae495%3Af51d%3Af1b7%3Af682\u0026initcwndbps=3721250\u0026mt=1776103796\u0026oweuc=\u0026pxtags=Cg4KAnR4Egg1MTgyODk2MQ\u0026rxtags=Cg4KAnR4Egg1MTgyODk1OQ%2CCg4KAnR4Egg1MTgyODk2MA%2CCg4KAnR4Egg1MTgyODk2MQ"}}}}}},"onTapOptions":{"accessibilityInfo":{"accessibilityLabel":"YouTube Channel Link: YEAR"}}},{"startIndex":371,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwiXs-i2t-uTAxWVwZUCHeqLFuJIiNyi2q299IePAcoBBKZEYJU=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa0puQnB1Wl9ETzQzR1FkLTR3b1J2cnJ1V2JqZ3xBQ3Jtc0tuRmJybUJxajRQUUx3Yno4M1p4TGxvZFo5N1VRbW0tbU5aZ2l1ZENfcjVNSjR6LXRkT2VBODVCUDBEdmtpSjZmUThCWmNfbUtuNUdqRmlrZ2pWTEUwMHp6S2VwZ1IydXBZN2QzRW5ESzZnZWhPSnBHTQ\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=jw_R6ttIrgg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa0puQn