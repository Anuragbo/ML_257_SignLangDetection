m/bookstore/books...\n\nFor free ASL Lessons see:    / billvicars  \nTo learn basic fingerspelling see    • ABC's in ASL: Learn how to Fingerspell!  \n\nAbout your instructor:\nhttp://www.lifeprint.com/asl101/pages...\nWarm regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":157,"length":11,"onTap":{"innertubeCommand":{"clickTrackingParams":"CI8CEM2rARgBIhMIl7PotrfrkwMVlcGVAh3qixbiygEEpkRglQ==","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=zTIJAgTai40","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"zTIJAgTai40","startTimeSeconds":0,"watchEndpointSupportedOnesieConfig":{"html5PlaybackOnesieConfig":{"commonConfig":{"url":"https://rr1---sn-bvvbaxivnuxqjvhj5nu-n4vs.googlevideo.com/initplayback?source=youtube\u0026oeis=1\u0026c=WEB\u0026oad=3200\u0026ovd=3200\u0026oaad=11000\u0026oavd=11000\u0026ocs=700\u0026oewis=1\u0026oputc=1\u0026ofpcc=1\u0026msp=1\u0026odepv=1\u0026id=cd32090204da8b8d\u0026ip=2601%3A642%3A4c01%3A9e6c%3Ae495%3Af51d%3Af1b7%3Af682\u0026initcwndbps=3721250\u0026mt=1776103796\u0026oweuc=\u0026pxtags=Cg4KAnR4Egg1MTgyODk2MQ\u0026rxtags=Cg4KAnR4Egg1MTgyODk1OQ%2CCg4KAnR4Egg1MTgyODk2MA%2CCg4KAnR4Egg1MTgyODk2MQ"}}}}}},"onTapOptions":{"accessibilityInfo":{"accessibilityLabel":"YouTube Channel Link: YEAR"}}},{"startIndex":371,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CI8CEM2rARgBIhMIl7PotrfrkwMVlcGVAh3qixbiSIjcotqtvfSHjwHKAQSmRGCV","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbmFXTjdmTXdlNFltZjVLM3NoRmRHbWNFVW1jd3xBQ3Jtc0trQklyX05OOF9rbUFoRTJ2dzh2dm5KRmxrUHJxU0d4bFpGbHg1TlhudXFJSlRyZW1RNzlhXzV4b1pISEVaVUR0aHZ3aXE1ZlIzMFM1Mi1yWGp0RGdaWkJtZmQ5dm9yNnFaNVk1R3I4ZTc0SW5FQjRtdw\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=jw_R6ttIrgg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_descripti