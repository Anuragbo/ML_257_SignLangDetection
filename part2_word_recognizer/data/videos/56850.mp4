sl101/pages...\nWarm regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":54,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CJYCEM2rARgBIhMIk_665LfrkwMVZa-KBx1H9CbWSIShsJyrxd3cogHKAQQuBaHo","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqblZNT180dkx4V0lqSVlDVDNrVEVLUnlObVZLZ3xBQ3Jtc0ttT1NxT1lWMS1EckNHNWJwYnJoM19BYk9Ua3hkbzRGWXJKNmhFOUdXQmJHakEtdHhJd0lubHNvd2ZmS3hLU1NDdHY1OTJDNF9GZXJ2NFhEN2NIREUwcjFsSVdKTDRpeEdBdC1TZ2JXcWpZRDhfeDhGaw\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=orl2KrOMEIQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqblZNT180dkx4V0lqSVlDVDNrVEVLUnlObVZLZ3xBQ3Jtc0ttT1NxT1lWMS1EckNHNWJwYnJoM19BYk9Ua3hkbzRGWXJKNmhFOUdXQmJHakEtdHhJd0lubHNvd2ZmS3hLU1NDdHY1OTJDNF9GZXJ2NFhEN2NIREUwcjFsSVdKTDRpeEdBdC1TZ2JXcWpZRDhfeDhGaw\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=orl2KrOMEIQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":166,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CJYCEM2rARgBIhMIk_665LfrkwMVZa-KBx1H9CbWSIShsJyrxd3cogHKAQQuBaHo","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbTBkd0lSOHNRQWJuN1BLZUthQ3daLWRKdmVLZ3xBQ3Jtc0trZy03OVJIUnh5VWRhdEZ6aEVzTUYyaTVyUEd1QkQ1UkZqLTJXQWJCaXNuUjZMWGxtaHpreVF6TTR4c0JfOWd2ck5HbHQtZkVwVHhQbHlBTXRuVjZWYjEtMndUZ0NEYUsyd2gwVVNnWUJWckdQUFpSTQ\u0026q=https%3A%2F%2Fwww.paypal.com%2Fcgi-bin%2Fwebscr%3Fcmd%3D_s-xclick%26hosted_button_id%3D64QMBRBXQSV6G\u0026v=orl2KrOMEIQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbTBkd0lSOHNRQWJuN1BLZUthQ3daLWRKdmVLZ3xBQ3Jtc0trZy03OVJIUnh5VWRhdEZ6aEVzTUYyaTVyUEd1QkQ1UkZqLTJXQWJCaXNuUjZMWGxtaHpr