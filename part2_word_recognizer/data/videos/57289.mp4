3426163465},"darkThemeColorPalette":{"baseBackground":4280093954,"raisedBackground":4281801481,"additiveBackground":734624070,"textPrimary":4294699743,"textSecondary":4293050278,"invertedBackground":4293109628,"overlayBackground":3426163465},"enableColorSampledText":true}},"viewCountType":"VIEW_COUNT_FACTOID_TYPE_TOTAL_VIEWS"}},{"factoidRenderer":{"value":{"simpleText":"2016"},"label":{"simpleText":"Aug 25"},"accessibilityText":"Aug 25, 2016","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4294964976,"raisedBackground":4294964976,"additiveBackground":566851910,"textPrimary":4281801481,"textSecondary":4286074161,"invertedBackground":4287645721,"overlayBackground":3426163465},"darkThemeColorPalette":{"baseBackground":4280093954,"raisedBackground":4281801481,"additiveBackground":734624070,"textPrimary":4294699743,"textSecondary":4293050278,"invertedBackground":4293109628,"overlayBackground":3426163465},"position":"FACTOID_POSITION_LAST","enableColorSampledText":true}}],"channelNavigationEndpoint":{"clickTrackingParams":"CBQQ040EGAYiEwjyiqmpuOuTAxUguysGHQbtCR_KAQSa58ig","commandMetadata":{"webCommandMetadata":{"url":"/@aslu","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCZy9xs6Tn9vWqN_5l0EEIZA","canonicalBaseUrl":"/@aslu"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/ytc/AIdro_k5Atr3lwlbXz7g9VDRZc1wpr5wE8Mj09QpZrSzo-CL8A=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"The \"TELL\" sign means \"say something to.\"  It can mean \"tell you.\" It could even mean \"state\" as in \"state your opinion\" which could be expressed as \"tell your opinion.\" American Sign Language - ASL  \nLearn sign language at https://www.Lifeprint.com\nDonations appreciated (to help pay for hosting and related expenses). Please help:   \nhttps://www.paypal.com/cgi-bin/webscr...\nThanks!\nOr, if you prefer \"Cash App\" you can use: https://cash.me/$Lifeprint\nWant to order a USB drive with four semesters worth of ASL instruction? (ASL 1, ASL 2, ASL 3, and ASL 4)  for $79.95?  \nSee \"SuperUSB\" in the ASLUniversity bookstore at: https://lifeprint.com/bookstore/books...\n\nFor free ASL Lessons see:    / billvicars  \nTo learn basic fingerspelling see    • ABC's in ASL: Learn how to Fingerspell!  \n\nAbout your instructor:\nhttp://www.lifeprint.com/asl101/pages...\nWarm regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":224,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBQQ040EGAYiEwjyiqmpuOuTAxUguysGHQbtCR9IrObXj8nLrutRygEEmufIoA==","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbUVfQkEtdndJeG9XWEZiMUo4MUhRaGdYeHZfd3xBQ3Jtc0trUWc3eklaUFQtdjBYdExkUVFVdWVzRlVKTXBmaDNib0x5RG9Ob0tCX3BDT1FDcUJVeElhUGI0bVFzMllNcGlPNERkcWdxUzFOWHpRVzUtRmwxeUYxMWpscWYxVTRQWnFSSlE2Z3FZb21fZXBsdHZxZw\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=Uda6XJH18yw","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbUVfQkEtdndJeG9XWEZiMUo4MUhRaGdYeHZfd3xBQ3Jtc0trUWc3eklaUFQtdjBYdExkUVFVdWVzRlVKTXBmaDNib0x5RG9Ob0tCX3BDT1FDcUJVeElhUGI0bVFzMllNcGlPNERkcWdxUzFOWHpRVzUtRmwxeUYxMWpscWYxVTRQWnFSSlE2Z3FZb21fZXBsdHZxZw\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=Uda6XJH18yw","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":336,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBQQ040EGAYiEwjyiqmpuOuTAxUguysGHQbtCR9IrObXj8nLrutRygEEmufIoA==","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redi