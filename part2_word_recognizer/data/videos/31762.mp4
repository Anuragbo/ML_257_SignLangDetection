 regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":72,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CJYCEM2rARgBIhMIvPfu3LfrkwMVKUjyAB3pFzpXSOiTg6nQhpupP8oBBLPQ0bI=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbHQxSGljM1BZX0RjLUVKVklJMG5iQ3RuYkg1UXxBQ3Jtc0ttYmJnRE5QU1d0WVRDY1B6NHJPTDJkMWs2TC1sTzFDN3p6NjVrZGE1UGpUUE5sM3d1R3E1NEcxRXZZMXZ3aUdSYnhNN2dpM0VUWjlzdkRSLW54STg2VTdCempyT1dadW9nR01kcGV4RVJiU0FmTWE5TQ\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=P1JsNQUgyeg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbHQxSGljM1BZX0RjLUVKVklJMG5iQ3RuYkg1UXxBQ3Jtc0ttYmJnRE5QU1d0WVRDY1B6NHJPTDJkMWs2TC1sTzFDN3p6NjVrZGE1UGpUUE5sM3d1R3E1NEcxRXZZMXZ3aUdSYnhNN2dpM0VUWjlzdkRSLW54STg2VTdCempyT1dadW9nR01kcGV4RVJiU0FmTWE5TQ\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=P1JsNQUgyeg","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":184,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CJYCEM2rARgBIhMIvPfu3LfrkwMVKUjyAB3pFzpXSOiTg6nQhpupP8oBBLPQ0bI=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFo3b3kwRmZJQjkySEFqVGxOa3JBSnFxNVVkUXxBQ3Jtc0tsTFRlV28tZzhIUm80SlQzeDhRZl9YY25lXzlJWjFJMUkzUUs1a3pzMGEzNVY0NzBocTVlUk1IUWlLd0MyV2xpQnZYU0RUZmhDTlVxTWl1RGdXVXJxOEFpNld5dFkzSkN5anhtQnhIcTQzdm15NlZaYw\u0026q=https%3A%2F%2Fwww.paypal.com%2Fcgi-bin%2Fwebscr%3Fcmd%3D_s-xclick%26hosted_button_id%3D64QMBRBXQSV6G\u0026v=P1JsNQUgyeg","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFo3b3kwRmZJQjkySEFqVGxOa3JBSnFxNVVkUXxBQ3Jtc0tsTFRlV28tZzhIUm80SlQzeDhRZl9YY25lXzlJWjFJMUkzUUs1a3pzMGEzNVY0NzBocTVlUk1IUWlLd0MyV2xpQnZY