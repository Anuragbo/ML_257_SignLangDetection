l101/pages...\nWarm regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":72,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CJYCEM2rARgBIhMIp4jjwLfrkwMVBEfyAB2DrzF7SJKijtP21sKavwHKAQQbEzuI","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqay1HQ1hibVgxYmRUVDNQSmk1T0lGVUdNbDVsZ3xBQ3Jtc0tub3pkc21pUGxpNTVBZ003YUhadFRITEUxMGd5R1I1ODVSc1N6NTh0NmF4QVNxaWMyajdqc09XeHJPYXBMNFVSZ19FNE9qUHFERDFFNV9DMFY0QzhSTngyTDZfNGZyN01oSWpqdmtXMnFLdjVuWXk5dw\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=vzUKt2pjkRI","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqay1HQ1hibVgxYmRUVDNQSmk1T0lGVUdNbDVsZ3xBQ3Jtc0tub3pkc21pUGxpNTVBZ003YUhadFRITEUxMGd5R1I1ODVSc1N6NTh0NmF4QVNxaWMyajdqc09XeHJPYXBMNFVSZ19FNE9qUHFERDFFNV9DMFY0QzhSTngyTDZfNGZyN01oSWpqdmtXMnFLdjVuWXk5dw\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=vzUKt2pjkRI","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":184,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CJYCEM2rARgBIhMIp4jjwLfrkwMVBEfyAB2DrzF7SJKijtP21sKavwHKAQQbEzuI","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa2RzNGJnOUxhREZwRm02SWJ4MkNHRWpyamd2UXxBQ3Jtc0trb2h3Z1R1VzNZdTJ4V3pEOHF3Nl82TmtrMi16Ti1OX0RLQkprZEFONUdaVjFvZnJBWW9FampVQXVZYzlaOGVvbFk4aTA3TWpFX3FoMFVOZGh6dlhzMm80QndNNmduZVExNjQtY3ZqdTk4NVRIVHhidw\u0026q=https%3A%2F%2Fwww.paypal.com%2Fcgi-bin%2Fwebscr%3Fcmd%3D_s-xclick%26hosted_button_id%3D64QMBRBXQSV6G\u0026v=vzUKt2pjkRI","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa2RzNGJnOUxhREZwRm02SWJ4MkNHRWpyamd2UXxBQ3Jtc0trb2h3Z1R1VzNZdTJ4V3pEOHF3Nl82TmtrMi16Ti1OX0RLQkprZEFONUdaVjFvZnJBWW9Fa