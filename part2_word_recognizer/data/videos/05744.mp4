ifeprint.com/bookstore/books...\n\nFor free ASL Lessons see:    / billvicars  \nTo learn basic fingerspelling see    • ABC's in ASL: Learn how to Fingerspell!  \n\nAbout your instructor:\nhttp://www.lifeprint.com/asl101/pages...\nWarm regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":72,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBQQ040EGAYiEwj77OCft-uTAxXviSsGHffqOCdI36e_7qu21f0yygEEgr9_Bg==","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbXJIQnRSeUJoaXFxb09LQkVJN3l0Ti1SSHFuUXxBQ3Jtc0trOE56clRjZ0N1SXJobHNIQzVIWEFOWTFiNXFKTEJvMjNVMy02QVdXWEJPVFBka3BIU09YSm1EUHdMSTlYTTVUd1dwNXI2LTdjZ056NGloTDVrYWF0Vi1OWVVsWE50dFFOUkFKeVZFZXA0YzZWLU8wcw\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=MvtVsr3P098","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbXJIQnRSeUJoaXFxb09LQkVJN3l0Ti1SSHFuUXxBQ3Jtc0trOE56clRjZ0N1SXJobHNIQzVIWEFOWTFiNXFKTEJvMjNVMy02QVdXWEJPVFBka3BIU09YSm1EUHdMSTlYTTVUd1dwNXI2LTdjZ056NGloTDVrYWF0Vi1OWVVsWE50dFFOUkFKeVZFZXA0YzZWLU8wcw\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=MvtVsr3P098","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":184,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBQQ040EGAYiEwj77OCft-uTAxXviSsGHffqOCdI36e_7qu21f0yygEEgr9_Bg==","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa0JQUW1HSE91Q2FHczJ6NHJSNk9pejdxQVduUXxBQ3Jtc0ttQUp3QmVmZjYzLS1TcGoxRTRSTUV6NnN2NVFMdEZwOEdGd3dveHNIMFlIZ2JTTGlzUVJlRmZwX3k2YXFmbzEyOHRqeXF2YWF2MWFRaGF0RFJuazNVUmRfdnhxV05fa1ZxTmVlOHJDRm1zSjZyallKQQ\u0026q=https%3A%2F%2Fwww.paypal.com%2Fcgi-bin%2Fwebscr%3Fcmd%3D_s-xclick%26hosted_button_id%3D64QMBRBXQSV6G\u0026v=MvtVsr3P098","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEn