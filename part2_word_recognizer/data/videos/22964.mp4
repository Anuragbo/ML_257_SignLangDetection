eful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":72,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwiYpsv6t-uTAxWYRvIAHVs3BH5Im63M5IHIvJapAcoBBJf3piw=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbDRZUGU1dS03eG9VbGdXUjVlVkRiLUlRMkM1Z3xBQ3Jtc0tuR0IzSnlVZ211WV9GMzFpQ0hBT3RCTktEcENldVNIc2V1dURpSkd0NnRLZkFpZDludkVSSVAwN2pqMHBoazFrLXhBX0hVWWhGR0dNbzJqckxYaUJGbW9raFJSbFVfTjJ2LWd4eW1sbmMzb1lkT1l4NA\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=qSzyQByTFps","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbDRZUGU1dS03eG9VbGdXUjVlVkRiLUlRMkM1Z3xBQ3Jtc0tuR0IzSnlVZ211WV9GMzFpQ0hBT3RCTktEcENldVNIc2V1dURpSkd0NnRLZkFpZDludkVSSVAwN2pqMHBoazFrLXhBX0hVWWhGR0dNbzJqckxYaUJGbW9raFJSbFVfTjJ2LWd4eW1sbmMzb1lkT1l4NA\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=qSzyQByTFps","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":184,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwiYpsv6t-uTAxWYRvIAHVs3BH5Im63M5IHIvJapAcoBBJf3piw=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbGxKdHQ4ZWNOVE9BZVR5Y2NXTktHaEo1MGNrZ3xBQ3Jtc0ttcG9lZGV0Ry01MmgwYnphYXRUclJTaE4wN0dBby12d2ZXWlJ0eFQydFczVW04SE1hVlRsYmx6NXlJYmM0Y3J1dmNnakM0RXZ1SEV2ZXJwSU5aaDJIS21lM2JGQ2NJWFhRTnpQWW9lMXFXUm5OemxGSQ\u0026q=https%3A%2F%2Fwww.paypal.com%2Fcgi-bin%2Fwebscr%3Fcmd%3D_s-xclick%26hosted_button_id%3D64QMBRBXQSV6G\u0026v=qSzyQByTFps","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbGxKdHQ4ZWNOVE9BZVR5Y2NXTktHaEo1MGNrZ3xBQ3Jtc0ttcG9lZGV0Ry01MmgwYnphYXRUclJTaE4wN0dBby12d2ZXWlJ0eFQydFczVW04SE1hVlRsYmx6NXlJYmM0Y3J1dmNnakM0RXZ1SEV2ZXJwSU5aaDJIS21lM2JGQ2NJWFhR