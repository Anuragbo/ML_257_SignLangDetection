ndpoint":{"browseId":"UCZy9xs6Tn9vWqN_5l0EEIZA","canonicalBaseUrl":"/@aslu"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/ytc/AIdro_k5Atr3lwlbXz7g9VDRZc1wpr5wE8Mj09QpZrSzo-CL8A=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"Family (non-initialized version). The American Sign Language (ASL) sign for \"family\" was traditionally signed for many years by moving \"F\"-handshapes in a horizontal circle.  This version of \"family\" is based on the same movement path as the initialized version of \"family\" but instead starts with loose \"5\"-hands and by the end of the sign the finger (and thumb) tips are pulled together. American Sign Language - ASL  \nLearn sign language at https://www.Lifeprint.com\nDonations appreciated (to help pay for hosting and related expenses). Please help:   \nhttps://www.paypal.com/cgi-bin/webscr...\nThanks!\nOr, if you prefer \"Cash App\" you can use: https://cash.me/$Lifeprint\nWant to order a USB drive with four semesters worth of ASL instruction? (ASL 1, ASL 2, ASL 3, and ASL 4)  for $79.95?  \nSee \"SuperUSB\" in the ASLUniversity bookstore at: https://lifeprint.com/bookstore/books...\n\nFor free ASL Lessons see:    / billvicars  \nTo learn basic fingerspelling see    • ABC's in ASL: Learn how to Fingerspell!  \n\nAbout your instructor:\nhttp://www.lifeprint.com/asl101/pages...\nWarm regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":444,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwjfu-3Vt-uTAxVTRvIAHULAJFlI6qPTlbOoxOrCAcoBBJluDxo=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa04xd3IwUWpZTXZYa1NiMFI1QkRkZkVrNUNyd3xBQ3Jtc0trSlJ4S01BX3Q5Z3N