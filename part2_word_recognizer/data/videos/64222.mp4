ED"},{"startIndex":410,"length":25,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":435,"length":87,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":522,"length":40,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":562,"length":51,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":613,"length":26,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":639,"length":171,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":810,"length":40,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":850,"length":28,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":878,"length":17,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":895,"length":35,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":930,"length":46,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":976,"length":25,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":1001,"length":40,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":1041,"length":67,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":1108,"length":9,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":1117,"length":2,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"}],"backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4294965232,"raisedBackground":4294965232,"additiveBackground":566854725,"textPrimary":4281736714,"textSecondary":4285420090,"invertedBackground":4287581977,"overlayBackground":3426098698},"darkThemeColorPalette":{"baseBackground":4280028674,"raisedBackground":4281736714,"additiveBackground":734626885,"textPrimary":4294634720,"textSecondary":4292723628,"invertedBackground":4293111164,"overlayBackground":3426098698},"colorSampledDescriptionBodyText":{"content":"YEAR: The ASL sign for \"year\" has two common versions:\n1. A longer version in which the dominant hand travels all the way around the non-dominant hand. See:    • YEAR  \n\n2. A more abbreviated \"advanced\" version of \"year\" in which the dominant hand makes a small forward rotation movement above the non-dominant hand.  \nSee:     • YEAR-[advanced-version]   American Sign Language - ASL  \nLearn sign language at https://www.Lifeprint.com\nDonations appreciated (to help pay for hosting and related expenses). Please help:   \nhttps://www.paypal.com/cgi-bin/webscr...\nThanks!\nOr, if you prefer \"Cash App\" you can use: https://cash.me/$Lifeprint\nWant to order a USB drive with four semesters worth of ASL instruction? (ASL 1, ASL 2, ASL 3, and ASL 4)  for $79.95?  \nSee \"SuperUSB\" in the ASLUniversity bookstore at: https://lifeprint.com/bookstore/books...\n\nFor free ASL Lessons see:    / billvicars  \nTo learn basic fingerspelling see    • ABC's in ASL: Learn how to Fingerspell!  \n\nAbout your instructor:\nhttp://www.lifeprint.com/asl101/pages...\nWarm regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":157,"length":11,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBUQ040EGAYiEwic9Oi2t-uTAxWpl9EEHaiYIEjKAQQiyLJB","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=zTIJAgTai40","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"zTIJAgTai40","startTimeSeconds":0,"watchEndpointSupportedOnesieConfig":{"html5PlaybackOnesieConfig":{"commonConfig":{"url":"https://rr1---sn-bvvbaxivnuxqjvhj5nu-n4vs.googlevideo.com/initplayback?source=youtube\u0026oeis=1\u0026c=WEB\u0026oad=3200\u0026ovd=3200\u0026oaad=11000\u0026oavd=11000\u0026ocs=700\u0026oewis=1\u0026oputc=1\u0026ofpcc=1\u0026msp=1\u0026odepv=1\u0026id=cd32090204da8b8d\u0026ip=2601%3A642%3A4c01%3A9e6c%3Ae495%3Af51d%3Af1b7%3Af682\u0026initcwndb