.com/asl101/pages...\nWarm regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":54,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CI8CEM2rARgBIhMIuo6lhbjrkwMVrr4rBh0Fqxa4SPrsrKSjm9O8U8oBBF6cUZw=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa1V3bVk5Zm4tOUpyaXp3cjdaVm1XWFM1WXhuZ3xBQ3Jtc0ttWGMzQmI4ajRHR3FGU2w2QWhDLTNzT2MyQ2xERFk3OGJ6RmduaTY4dU9neEdpTFkyODB1VEI5TnEtbm5CY1B1WUNqM1RxQklObDdoRFBqekxwcGtPbUZ6ZDM1RzEtX0loZTYxd1NIMjFOQkVBVFJJVQ\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=U3lM2jSLNno","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa1V3bVk5Zm4tOUpyaXp3cjdaVm1XWFM1WXhuZ3xBQ3Jtc0ttWGMzQmI4ajRHR3FGU2w2QWhDLTNzT2MyQ2xERFk3OGJ6RmduaTY4dU9neEdpTFkyODB1VEI5TnEtbm5CY1B1WUNqM1RxQklObDdoRFBqekxwcGtPbUZ6ZDM1RzEtX0loZTYxd1NIMjFOQkVBVFJJVQ\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=U3lM2jSLNno","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":166,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CI8CEM2rARgBIhMIuo6lhbjrkwMVrr4rBh0Fqxa4SPrsrKSjm9O8U8oBBF6cUZw=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa2djd3p2bmdtYS1BV1dyeHlRQTRkd2JXOFJqUXxBQ3Jtc0trZU9ZWkhqcVlBTXNQeUx6cUZ0ZjdDS19XQk53dFBoNEhQOGY3T1ZBcmkxTnA4WDg0QU9IY1RoZHh6WFVUMlN1YVprSVNjYUpGa3VleE44TUVKUnBnb0hTd0ItWVBkRm5DVjNEd2JONnp4cldaamlnNA\u0026q=https%3A%2F%2Fwww.paypal.com%2Fcgi-bin%2Fwebscr%3Fcmd%3D_s-xclick%26hosted_button_id%3D64QMBRBXQSV6G\u0026v=U3lM2jSLNno","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa2djd3p2bmdtYS1BV1dyeHlRQTRkd2JXOFJqUXxBQ3Jtc0trZU9ZWkhqcVlBTXNQeUx6cUZ0ZjdDS19XQk53dFBoNEhQOGY3T1ZBcmkxTnA4WD