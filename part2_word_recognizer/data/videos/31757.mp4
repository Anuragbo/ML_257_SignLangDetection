 regards and love to you all.\nI am grateful for your support.\nDr. Bill\n:)","commandRuns":[{"startIndex":54,"length":25,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwi2uuHct-uTAxUw4JQJHULoJ5VI7f6e2KT6zY_sAcoBBED8Lhk=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa0RXdTIwbUZUdXFUUF8tU2VDSzRlZ2JaZVZPQXxBQ3Jtc0trLTlLaDRZR2lMWVZrUi1zX1NOaHlKMG5HUWptVVhuT2R1RDRUOHlreUdLRmpFYk40UV9sSWZiLUExX3o0TEd3YV92cms5czc3Tm16ckI1NU1RU05mMmVlQXFZMDBUVDBVX2lFbEVXMDY5MU5ZTDNJUQ\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=7B830ksHv20","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa0RXdTIwbUZUdXFUUF8tU2VDSzRlZ2JaZVZPQXxBQ3Jtc0trLTlLaDRZR2lMWVZrUi1zX1NOaHlKMG5HUWptVVhuT2R1RDRUOHlreUdLRmpFYk40UV9sSWZiLUExX3o0TEd3YV92cms5czc3Tm16ckI1NU1RU05mMmVlQXFZMDBUVDBVX2lFbEVXMDY5MU5ZTDNJUQ\u0026q=https%3A%2F%2Fwww.Lifeprint.com%2F\u0026v=7B830ksHv20","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":166,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwi2uuHct-uTAxUw4JQJHULoJ5VI7f6e2KT6zY_sAcoBBED8Lhk=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbTJJNlFiX09RcWFEb1NDemhiRTNDUGJlZkdnd3xBQ3Jtc0tuaGxVVi1DV20xN0pRYUxkYmtGUTVSZUtmaU1YX1ZZLUFfSXJBcTNWN1JCZVNLbUFpV25NNzZKQlRYai03UVlpenF1c0JwOW5hZ1BfdFh3NS1qS0J3R3N6X0NheU5Fc1UxUG5zeEtZaTNLUXZkQXlfRQ\u0026q=https%3A%2F%2Fwww.paypal.com%2Fcgi-bin%2Fwebscr%3Fcmd%3D_s-xclick%26hosted_button_id%3D64QMBRBXQSV6G\u0026v=7B830ksHv20","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbTJJNlFiX09RcWFEb1NDemhiRTNDUGJlZkdnd3xBQ3Jtc0tuaGxVVi1DV20xN0pRYUxkYmtGUTVSZUtmaU1YX1ZZLUFfSXJBcTNWN1JCZVNLbUFpV25NNzZKQlRYai03UVlpenF1